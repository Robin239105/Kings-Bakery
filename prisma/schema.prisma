// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Product {
  id            String         @id @default(cuid())
  slug          String         @unique
  name          String
  description   String
  shortTag      String?        // e.g. "Best Seller", "New"
  category      Category       @relation(fields: [categoryId], references: [id])
  categoryId    String
  price         Decimal        @db.Decimal(10, 2)
  images        ProductImage[]
  dietaryTags   DietaryTag[]   @relation("ProductDietaryTags")
  ingredients   String[]
  allergens     String[]
  shelfLifeDays Int            @default(3)
  isFeatured    Boolean        @default(false)
  isActive      Boolean        @default(true)
  stockStatus   StockStatus    @default(IN_STOCK)
  reviews       Review[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([categoryId])
  @@index([slug])
  @@index([isActive])
}

model ProductImage {
  id         String   @id @default(cuid())
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId  String
  url        String
  altText    String
  sortOrder  Int      @default(0)

  @@index([productId])
}

model Category {
  id       String    @id @default(cuid())
  slug     String    @unique
  name     String    // Cakes, Tarts, Pastries, Macarons
  products Product[]
}

model DietaryTag {
  id       String    @id @default(cuid())
  label    String    @unique // Gluten-Free, Vegan, Nut-Free
  products Product[] @relation("ProductDietaryTags")
}

enum StockStatus {
  IN_STOCK
  LOW_STOCK
  OUT_OF_STOCK
}

model TastingBox {
  id           String           @id @default(cuid())
  slug         String           @unique
  name         String
  description  String
  itemCount    Int
  price        Decimal          @db.Decimal(10, 2)
  heroImageUrl String
  contents     TastingBoxItem[]
  isActive     Boolean          @default(true)
  createdAt    DateTime         @default(now())

  @@index([slug])
  @@index([isActive])
}

model TastingBoxItem {
  id           String     @id @default(cuid())
  box          TastingBox @relation(fields: [boxId], references: [id], onDelete: Cascade)
  boxId        String
  name         String
  thumbnailUrl String
  isSwappable  Boolean    @default(false)

  @@index([boxId])
}

model Review {
  id         String   @id @default(cuid())
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId  String
  authorName String
  rating     Int      // 1-5
  comment    String
  isVerified Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@index([productId])
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique // e.g. KB-2026-0001
  customerName    String
  customerEmail   String
  customerPhone   String
  deliveryAddress String
  deliveryNotes   String?
  isGift          Boolean     @default(false)
  giftMessage     String?
  deliveryDate    DateTime
  deliveryWindow  String      // "10am-12pm" etc
  items           OrderItem[]
  subtotal        Decimal     @db.Decimal(10, 2)
  deliveryFee     Decimal     @db.Decimal(10, 2)
  total           Decimal     @db.Decimal(10, 2)
  promoCode       String?
  status          OrderStatus @default(PENDING)
  createdAt       DateTime    @default(now())

  @@index([orderNumber])
  @@index([status])
  @@index([deliveryDate])
}

model OrderItem {
  id           String  @id @default(cuid())
  order        Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId      String
  productId    String?
  tastingBoxId String?
  name         String  // denormalized snapshot at time of order
  unitPrice    Decimal @db.Decimal(10, 2)
  quantity     Int

  @@index([orderId])
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

model DeliverySlot {
  id            String   @id @default(cuid())
  date          DateTime @unique
  isFullyBooked Boolean  @default(false)
  capacity      Int      @default(20)
  bookedCount   Int      @default(0)

  @@index([date])
}

model BlogPost {
  id              String   @id @default(cuid())
  slug            String   @unique
  title           String
  excerpt         String
  bodyHtml        String   // rich content stored as sanitized HTML or MDX string
  category        String   // Technique, Ingredients, Behind the Scenes, Seasonal
  heroImageUrl    String
  authorName      String
  authorAvatarUrl String
  readTimeMins    Int      @default(5)
  isFeatured      Boolean  @default(false)
  publishedAt     DateTime @default(now())

  @@index([slug])
  @@index([isFeatured])
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  createdAt DateTime @default(now())
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         String   @default("admin")
  createdAt    DateTime @default(now())
}
